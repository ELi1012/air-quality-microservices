{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["./app.js", "**/*.ts"],
  "exclude": [
    "node_modules",
    "dist"
  ],
}