# syntax=docker/dockerfile:1
FROM alpine:3.20


WORKDIR /srv/client

# note: this image must be built from the common root `~/projects/air_quality`
COPY air-quality-dashboard-daycare/client /srv/client

RUN set -eux; \
    apk --no-cache add \
        nodejs \
        npm; \
    npm install; \
    npm run build

EXPOSE 8080/tcp

CMD ["npm", "run", "start"]
